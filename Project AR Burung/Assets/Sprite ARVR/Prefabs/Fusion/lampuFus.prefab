--- !u!114 &7870340031191910564
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 4176463012200614970}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Langkah-langkah Pembuatan lampu tidur mini.\r\nBahan : Lampu LED kecil
    3mm atau 5mm , Baterai , kawat tembaga tipis , resistor (jika diperlukan, tergantung
    spesifikasi lampu LED)\r\nwadah untuk lampu , lem.\r\n\r\n- Identifikasi kaki
    positif (+) dan negatif (-) dari lampu LED\r\n- Hubungkan kaki positif LED ke
    terminal positif baterai , Hubungkan kaki negatif LED ke terminal negatif baterai.\r\n-
    Jika LED terlalu terang, tambahkan resistor di antara salah satu koneksi untuk
    mengurangi cahaya.\r\n- Gunakan lem untuk menempelkan kabel kaki LED ke baterai.
    \r\n- Letakkan LED dan baterai ke dalam wadah yang Anda pilih. Lampu tidur mini
